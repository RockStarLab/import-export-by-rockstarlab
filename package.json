{
  "name": "boilerplate",
  "version": "1.0.1",
  "description": "**Requirements**",
  "main": "index.js",
  "scripts": {
    "initNewProject": "gulp initNewProject",
    "dev": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "mix --production",
    "watch-prod": "mix --production -- --watch --progress",
    "e2e:install": "node scripts/check-node.js && PLAYWRIGHT_BROWSERS_PATH=./e2e/.playwright-browsers node node_modules/playwright/cli.js install",
    "e2e:seed": "node scripts/check-node.js && PLAYWRIGHT_BROWSERS_PATH=./e2e/.playwright-browsers node e2e/manual/seed-posts.mjs",
    "e2e:seed:headed": "node scripts/check-node.js && PLAYWRIGHT_BROWSERS_PATH=./e2e/.playwright-browsers node e2e/manual/seed-posts.mjs --headed",
    "prepare": "husky"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bilberrry-wp/boilerplate/issues"
  },
  "homepage": "https://github.com/bilberrry-wp/boilerplate#readme",
  "devDependencies": {
    "@babel/cli": "^7.17.6",
    "@babel/core": "^7.17.8",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-env": "^7.16.11",
    "@babel/runtime": "^7.17.8",
    "@playwright/test": "^1.48.2",
    "@wordpress/prettier-config": "^4.0.0",
    "babel-preset-es2015": "^6.24.1",
    "babel-preset-es2016": "^6.24.1",
    "babel-preset-es2017": "^6.24.1",
    "browser-sync": "^3.0.2",
    "browser-sync-webpack-plugin": "^2.3.0",
    "fs": "^0.0.1-security",
    "gulp": "^4.0.2",
    "gulp-autoprefixer": "^8.0.0",
    "gulp-babel": "^8.0.0",
    "gulp-cli": "^2.3.0",
    "gulp-concat": "^2.6.1",
    "gulp-plumber": "^1.2.1",
    "gulp-postcss": "^9.0.1",
    "gulp-rename": "^2.0.0",
    "gulp-rollup": "^2.17.0",
    "gulp-sass": "^5.1.0",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-string-replace": "^1.1.2",
    "gulp-uglify-es": "^3.0.0",
    "husky": ">=6",
    "laravel-mix": "^6.0.49",
    "lint-staged": "^15.2.7",
    "merge2": "^1.4.1",
    "playwright": "^1.48.2",
    "prettier": "npm:wp-prettier@latest",
    "resolve-url-loader": "5.0.0",
    "rollup-plugin-node-resolve": "^5.2.0",
    "sass": "^1.49.9",
    "sass-loader": "12.1.0",
    "slick-carousel": "^1.8.1"
  },
  "dependencies": {
    "glightbox": "^3.3.0",
    "js-cookie": "^3.0.5",
    "select2": "^4.1.0-rc.0"
  },
  "lint-staged": {
    "*.{js,scss,css,md}": "prettier --write"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
