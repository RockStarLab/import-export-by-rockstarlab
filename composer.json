{
	"name": "rockstarlab/import-export-by-rockstarlab",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "rockstarlab"
		}
	],
	"scripts": {
		"lint": "phpcs --standard=./.phpcs.xml.dist --report=diff -d memory_limit=2046M",
		"fix": "phpcbf --standard=./.phpcs.xml.dist || true",
		"post-install-cmd": [
			"@php ./vendor/bin/phpcs --config-set installed_paths vendor/wp-coding-standards/wpcs,vendor/phpcompatibility/php-compatibility,vendor/phpcsstandards/phpcsextra,vendor/phpcsstandards/phpcsutils"
		],
		"post-update-cmd": [
			"@php ./vendor/bin/phpcs --config-set installed_paths vendor/wp-coding-standards/wpcs,vendor/phpcompatibility/php-compatibility,vendor/phpcsstandards/phpcsextra,vendor/phpcsstandards/phpcsutils"
		]
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"phpcompatibility/php-compatibility": "^9.3",
		"phpcsstandards/phpcsextra": "^1.1",
		"phpcsstandards/phpcsutils": "^1.0",
		"squizlabs/php_codesniffer": "^3.7.2",
		"wp-coding-standards/wpcs": "^3.0"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"preferred-install": "dist",
		"optimize-autoloader": true,
		"sort-packages": true,
		"platform-check": false
	},
	"require": {
		"phpoffice/phpspreadsheet": "^1.30.6"
	}
}
